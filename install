#!/usr/bin/env bash
set -euo pipefail
APP=grexcode

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO="grexlabs/real_grexcode"

usage() {
    cat <<EOF
Grexcode Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 0.0.1)
    -b, --binary <path>     Install from a local binary instead of downloading
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Examples:
    curl -fsSL https://raw.githubusercontent.com/$REPO/refs/heads/main/install | bash
    curl -fsSL https://raw.githubusercontent.com/$REPO/refs/heads/main/install | bash -s -- --version 0.0.1
    ./install --binary /path/to/grexcode

Supported platforms:
    linux-x64, linux-arm64, linux-armv7
    darwin-x64, darwin-arm64
    windows-x64
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        -v|--version)
            [[ -n "${2:-}" ]] || { echo -e "${RED}Error: --version requires a version${NC}"; exit 1; }
            requested_version="$2"; shift 2 ;;
        -b|--binary)
            [[ -n "${2:-}" ]] || { echo -e "${RED}Error: --binary requires a path${NC}"; exit 1; }
            binary_path="$2"; shift 2 ;;
        --no-modify-path) no_modify_path=true; shift ;;
        *) echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2; shift ;;
    esac
done

INSTALL_DIR="${GREXCODE_INSTALL_DIR:-$HOME/.grexcode/bin}"
mkdir -p "$INSTALL_DIR"

if [ -n "$binary_path" ]; then
    [ -f "$binary_path" ] || { echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"; exit 1; }
    specific_version="local"
else
    raw_os=$(uname -s)
    case "$raw_os" in
        Darwin*) os="darwin" ;;
        Linux*) os="linux" ;;
        MINGW*|MSYS*|CYGWIN*) os="windows" ;;
        *) echo -e "${RED}Error: Unsupported OS: $raw_os${NC}"; exit 1 ;;
    esac

    arch=$(uname -m)
    case "$arch" in
        aarch64|arm64) arch="arm64" ;;
        x86_64|amd64) arch="x64" ;;
        armv7*|armhf) arch="armv7" ;;
        i686|i386) arch="x86" ;;
        *) echo -e "${RED}Error: Unsupported architecture: $arch${NC}"; exit 1 ;;
    esac

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
        rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
        [ "$rosetta_flag" = "1" ] && arch="arm64"
    fi

    combo="$os-$arch"
    case "$combo" in
        linux-x64|linux-arm64|linux-armv7|darwin-x64|darwin-arm64|windows-x64) ;;
        *) echo -e "${RED}Error: No prebuilt binary for $combo${NC}"; exit 1 ;;
    esac

    archive_ext=".tar.gz"
    [ "$os" = "windows" ] && archive_ext=".zip"

    is_musl=false
    if [ "$os" = "linux" ]; then
        [ -f /etc/alpine-release ] && is_musl=true
        command -v ldd >/dev/null 2>&1 && ldd --version 2>&1 | grep -qi musl && is_musl=true
    fi

    needs_baseline=false
    if [ "$arch" = "x64" ] && [ "$os" = "linux" ]; then
        grep -qwi avx2 /proc/cpuinfo 2>/dev/null || needs_baseline=true
    fi

    target="$os-$arch"
    [ "$needs_baseline" = "true" ] && target="$target-baseline"
    [ "$is_musl" = "true" ] && target="$target-musl"

    filename="$APP-$target$archive_ext"

    if [ "$os" = "linux" ]; then
        command -v tar >/dev/null 2>&1 || { echo -e "${RED}Error: 'tar' is required${NC}"; exit 1; }
    else
        command -v unzip >/dev/null 2>&1 || { echo -e "${RED}Error: 'unzip' is required${NC}"; exit 1; }
    fi

    if [ -z "$requested_version" ]; then
        echo -e "${MUTED}Fetching latest version...${NC}"
        specific_version=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | grep '"tag_name"' | head -1 | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')
        if [ -z "$specific_version" ]; then
            echo -e "${RED}Error: Could not fetch latest version${NC}"
            echo -e "${MUTED}Check: https://github.com/$REPO/releases${NC}"
            exit 1
        fi
    else
        requested_version="${requested_version#v}"
        specific_version="$requested_version"
    fi

    url="https://github.com/$REPO/releases/download/v${specific_version}/$filename"
    echo -e "${MUTED}Downloading $filename (v$specific_version)...${NC}"

    tmp_dir=$(mktemp -d)
    trap "rm -rf '$tmp_dir'" EXIT

    if ! curl -fsSL -w '' -o "$tmp_dir/$filename" "$url"; then
        echo -e "${RED}Error: Failed to download $url${NC}"
        echo -e "${MUTED}Available releases: https://github.com/$REPO/releases${NC}"
        exit 1
    fi

    file_type=$(file -b "$tmp_dir/$filename" 2>/dev/null || echo "unknown")
    echo -e "${MUTED}File type: $file_type${NC}"

    if echo "$file_type" | grep -qi "gzip\|tar"; then
        tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
    elif echo "$file_type" | grep -qi "zip"; then
        unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
    elif echo "$file_type" | grep -qi "text\|script\|ASCII"; then
        echo -e "${ORANGE}Warning: Downloaded file is not a binary archive.${NC}"
        echo -e "${ORANGE}This may be a placeholder. Check https://github.com/$REPO/releases${NC}"
        rm -rf "$tmp_dir"
        exit 1
    else
        echo -e "${RED}Error: Unknown file format: $file_type${NC}"
        rm -rf "$tmp_dir"
        exit 1
    fi

    mv "$tmp_dir/$APP" "$INSTALL_DIR/"
    chmod 755 "$INSTALL_DIR/$APP"
    rm -rf "$tmp_dir"
fi

add_to_path() {
    local config_file=$1
    local command=$2
    if grep -Fxq "$command" "$config_file" 2>/dev/null; then
        echo -e "${MUTED}Already in $config_file, skipping.${NC}"
    elif [[ -w $config_file ]]; then
        echo -e "\n# grexcode" >> "$config_file"
        echo "$command" >> "$config_file"
        echo -e "${GREEN}Added grexcode to PATH in $config_file${NC}"
    fi
}

if [[ "$no_modify_path" != "true" ]] && [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    current_shell=$(basename "$SHELL" 2>/dev/null || echo "bash")
    config_file=""
    case "$current_shell" in
        fish) config_file="$HOME/.config/fish/config.fish" ;;
        zsh)  config_file="${ZDOTDIR:-$HOME}/.zshrc" ;;
        bash) config_file="$HOME/.bashrc" ;;
        *)    config_file="$HOME/.bashrc" ;;
    esac

    if [[ -n "$config_file" ]]; then
        add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
    else
        echo -e "${ORANGE}Add to your PATH:${NC}"
        echo -e "  export PATH=$INSTALL_DIR:\$PATH"
    fi
fi

echo -e ""
echo -e "${MUTED}                    ${NC}             ▄     "
echo -e "${MUTED}█▀▀█ █▀▀█ █▀▀▀ █░█░█ ${NC}█▀▀▀ █▀▀█ █▀▀▄ █▀▀ "
echo -e "${MUTED}█░▄▄ █▄▄▀ █▀▀░ ▀▄▀▄▀ ${NC}█░░░ █░░█ █░█░ █▀▀ "
echo -e "${MUTED}▀▀▀▀ ▀░▀▀ ▀▀▀▀ ░▀░▀░ ${NC}▀▀▀▀ ▀▀▀▀ ▀▀▀░ ▀▀▀ "
echo -e ""
echo -e "${GREEN}Grexcode v$specific_version installed!${NC}"
echo -e ""
echo -e "  cd <project>  ${MUTED}# Open directory${NC}"
echo -e "  grexcode      ${MUTED}# Run Grexcode${NC}"
echo -e ""
echo -e "${MUTED}Docs: ${NC}https://grexcode.ai/docs"
echo -e "${MUTED}Releases: ${NC}https://github.com/$REPO/releases"
echo -e ""
