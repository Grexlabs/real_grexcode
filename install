#!/usr/bin/env bash
set -euo pipefail
APP=grexcode
VERSION="1.2.1"

GREEN_DARK='\033[0;32m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
MUTED='\033[0;2m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

REPO="grexlabs/real_grexcode"
REPO_URL="https://github.com/$REPO"

banner() {
    echo -e ""
    echo -e "${GREEN}                    ${NC}             ${GREEN}▄${NC}     "
    echo -e "${GREEN}█▀▀█ █▀▀█ █▀▀▀ █░█░█ ${NC}${GREEN}█▀▀▀ █▀▀█ █▀▀▄ █▀▀ ${NC}"
    echo -e "${GREEN}█░▄▄ █▄▄▀ █▀▀░ ▀▄▀▄▀ ${NC}${GREEN}█░░░ █░░█ █░█░ █▀▀ ${NC}"
    echo -e "${GREEN}▀▀▀▀ ▀░▀▀ ▀▀▀▀ ░▀░▀░ ${NC}${GREEN}▀▀▀▀ ▀▀▀▀ ▀▀▀░ ▀▀▀ ${NC}"
    echo -e ""
}

# Green progress bar: ████████████░░░░░░░░ 52%
progress_bar() {
    local current=$1
    local total=$2
    local width=40
    local percent=$((current * 100 / total))
    local filled=$((current * width / total))
    local empty=$((width - filled))

    printf "\r  ${GREEN}"
    for ((i=0; i<filled; i++)); do printf '█'; done
    printf "${MUTED}"
    for ((i=0; i<empty; i++)); do printf '░'; done
    printf "${NC} ${GREEN}%3d%%${NC}" "$percent"
}

usage() {
    banner
    cat <<EOF
${GREEN}Grexcode${NC} v${VERSION} - The open source coding agent

${GREEN}Usage:${NC}
    install.sh [options]

${GREEN}Options:${NC}
    -h, --help              Display this help message
    -v, --version <ver>     Install a specific version
    -b, --binary <path>     Install from a local binary
        --no-modify-path    Don't modify shell config files

${GREEN}Supported platforms:${NC}
    linux-x64, linux-arm64, linux-armv7
    darwin-x64, darwin-arm64
    windows-x64

${GREEN}Quick install:${NC}
    curl -fsSL https://raw.githubusercontent.com/$REPO/main/install | bash

${GREEN}Docs:${NC} https://grexcode.ai/docs
${GREEN}Source:${NC} $REPO_URL
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        -v|--version) requested_version="${2:-}"; shift 2 ;;
        -b|--binary) binary_path="${2:-}"; shift 2 ;;
        --no-modify-path) no_modify_path=true; shift ;;
        *) shift ;;
    esac
done

INSTALL_DIR="${GREXCODE_INSTALL_DIR:-$HOME/.grexcode/bin}"
mkdir -p "$INSTALL_DIR"

if [ -n "$binary_path" ]; then
    [ -f "$binary_path" ] || { echo -e "${RED}Error: Binary not found: ${binary_path}${NC}"; exit 1; }
    cp "$binary_path" "$INSTALL_DIR/$APP"
    chmod 755 "$INSTALL_DIR/$APP"
    specific_version="local"
else
    raw_os=$(uname -s)
    case "$raw_os" in
        Darwin*) os="darwin" ;;
        Linux*) os="linux" ;;
        MINGW*|MSYS*|CYGWIN*) os="windows" ;;
        *) echo -e "${RED}Error: Unsupported OS: $raw_os${NC}"; exit 1 ;;
    esac

    arch=$(uname -m)
    case "$arch" in
        aarch64|arm64) arch="arm64" ;;
        x86_64|amd64) arch="x64" ;;
        armv7*|armhf) arch="armv7" ;;
        *) echo -e "${RED}Error: Unsupported arch: $arch${NC}"; exit 1 ;;
    esac

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
        rosetta=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
        [ "$rosetta" = "1" ] && arch="arm64"
    fi

    combo="$os-$arch"
    case "$combo" in
        linux-x64|linux-arm64|linux-armv7|darwin-x64|darwin-arm64|windows-x64) ;;
        *) echo -e "${RED}Error: No prebuilt binary for $combo${NC}"; exit 1 ;;
    esac

    if [ -z "$requested_version" ]; then
        echo -e "${MUTED}Fetching latest version...${NC}"
        specific_version=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')
        [ -n "$specific_version" ] || { echo -e "${RED}Error: Could not fetch latest version${NC}"; exit 1; }
    else
        specific_version="${requested_version#v}"
    fi

    url="https://github.com/$REPO/releases/download/v${specific_version}/${APP}-${combo}.tar.gz"
    banner

    tmp_dir=$(mktemp -d)
    trap "rm -rf '$tmp_dir'" EXIT

    # Get file size first
    file_size=$(curl -sIL "$url" | grep -i content-length | tail -1 | tr -d '\r' | awk '{print $2}')
    file_size=${file_size:-0}

    echo -e "${GREEN}  ⬇ Downloading${NC} ${APP}-${combo}.tar.gz"
    echo ""

    # Download with green progress bar
    if [ "$file_size" -gt 0 ] 2>/dev/null; then
        curl -L --fail -o "$tmp_dir/archive.tar.gz" "$url" --progress-bar 2>&1 | while IFS= read -r line; do
            case "$line" in
                *[0-9]*%*)
                    # Extract percentage from curl output
                    pct=$(echo "$line" | grep -oE '[0-9]+' | tail -1)
                    if [ -n "$pct" ]; then
                        filled=$((pct * 40 / 100))
                        empty=$((40 - filled))
                        printf "\r  ${GREEN}"
                        for ((i=0; i<filled; i++)); do printf '█'; done
                        printf "${MUTED}"
                        for ((i=0; i<empty; i++)); do printf '░'; done
                        printf "${NC} ${GREEN}%3d%%${NC}" "$pct"
                    fi
                    ;;
            esac
        done
        echo ""
    else
        curl -L --fail --progress-bar -o "$tmp_dir/archive.tar.gz" "$url" 2>&1
        echo ""
    fi

    # Check download
    if [ ! -f "$tmp_dir/archive.tar.gz" ] || [ ! -s "$tmp_dir/archive.tar.gz" ]; then
        url="https://github.com/$REPO/releases/download/v${specific_version}/${APP}-${combo}.zip"
        echo -e "${GREEN}  ⬇ Trying zip...${NC}"
        curl -L --fail --progress-bar -o "$tmp_dir/archive.zip" "$url" 2>&1 || {
            echo -e "${RED}  ✗ Download failed${NC}"
            echo -e "${MUTED}  Check: $REPO_URL/releases${NC}"
            exit 1
        }
    fi

    echo -ne "${GREEN}  ⚙ Extracting...${NC} "
    if [ -f "$tmp_dir/archive.zip" ]; then
        unzip -q "$tmp_dir/archive.zip" -d "$tmp_dir" 2>/dev/null
    else
        tar -xzf "$tmp_dir/archive.tar.gz" -C "$tmp_dir" 2>/dev/null
    fi
    echo -e "${GREEN}done${NC}"

    mv "$tmp_dir/$APP" "$INSTALL_DIR/"
    chmod 755 "$INSTALL_DIR/$APP"
fi

# Add to PATH and auto-source
added_to_path=false
if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    current_shell=$(basename "$SHELL" 2>/dev/null || echo "bash")
    case "$current_shell" in
        fish) cfg="$HOME/.config/fish/config.fish" ;;
        zsh)  cfg="${ZDOTDIR:-$HOME}/.zshrc" ;;
        *)    cfg="$HOME/.bashrc" ;;
    esac

    if [ -f "$cfg" ] && [[ -w "$cfg" ]]; then
        if ! grep -Fxq "export PATH=$INSTALL_DIR:\$PATH" "$cfg" 2>/dev/null; then
            echo -e "\n# grexcode" >> "$cfg"
            echo "export PATH=$INSTALL_DIR:\$PATH" >> "$cfg"
            added_to_path=true
        fi
    fi
fi

# Export PATH for current session
export PATH="$INSTALL_DIR:$PATH"

# Auto-source shell config so grexcode is available immediately
current_shell=$(basename "$SHELL" 2>/dev/null || echo "bash")
case "$current_shell" in
    fish) cfg="$HOME/.config/fish/config.fish" ;;
    zsh)  cfg="${ZDOTDIR:-$HOME}/.zshrc" ;;
    *)    cfg="$HOME/.bashrc" ;;
esac
[ -f "$cfg" ] && source "$cfg" 2>/dev/null || true

echo ""
banner
echo -e "${GREEN}  ✓ Grexcode v${specific_version} installed successfully!${NC}"
echo ""

# Verify installation
if command -v grexcode >/dev/null 2>&1; then
    installed_version=$(grexcode --version 2>/dev/null || echo "$specific_version")
    echo -e "${GREEN}  ✓${NC} grexcode is ready to use"
    echo -e "${GREEN}  ✓${NC} Version: ${installed_version}"
else
    echo -e "${GREEN}  ✓${NC} Installed to: ${INSTALL_DIR}/grexcode"
fi

if [ "$added_to_path" = true ]; then
    echo -e "${GREEN}  ✓${NC} Added to PATH in ${cfg}"
fi

echo ""
echo -e "${GREEN}  Quick start:${NC}"
echo -e "    cd <project>      ${MUTED}# Open directory${NC}"
echo -e "    grexcode          ${MUTED}# Start Grexcode${NC}"
echo ""
echo -e "${GREEN}  Commands:${NC}"
echo -e "    ${GREEN}/${NC}                 ${MUTED}# Show all commands${NC}"
echo -e "    ${GREEN}@${NC}                 ${MUTED}# Explore files${NC}"
echo -e "    grexcode --help   ${MUTED}# Show help${NC}"
echo -e "    grexcode --contact ${MUTED}# Join Telegram${NC}"
echo ""
echo -e "${MUTED}  Docs:${NC} https://grexcode.ai/docs"
echo -e "${MUTED}  Source:${NC} $REPO_URL"
echo ""
