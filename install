#!/usr/bin/env bash
set -euo pipefail
APP=grexcode

MUTED='\033[0;2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO="grexlabs/real_grexcode"

usage() {
    cat <<EOF
Grexcode Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version
    -b, --binary <path>     Install from a local binary
        --no-modify-path    Don't modify shell config files
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        -v|--version) requested_version="${2:-}"; shift 2 ;;
        -b|--binary) binary_path="${2:-}"; shift 2 ;;
        --no-modify-path) no_modify_path=true; shift ;;
        *) shift ;;
    esac
done

INSTALL_DIR="${GREXCODE_INSTALL_DIR:-$HOME/.grexcode/bin}"
mkdir -p "$INSTALL_DIR"

if [ -n "$binary_path" ]; then
    [ -f "$binary_path" ] || { echo -e "${RED}Binary not found: ${binary_path}${NC}"; exit 1; }
    cp "$binary_path" "$INSTALL_DIR/$APP"
    chmod 755 "$INSTALL_DIR/$APP"
    specific_version="local"
else
    raw_os=$(uname -s)
    case "$raw_os" in
        Darwin*) os="darwin" ;;
        Linux*) os="linux" ;;
        MINGW*|MSYS*|CYGWIN*) os="windows" ;;
        *) echo -e "${RED}Unsupported OS: $raw_os${NC}"; exit 1 ;;
    esac

    arch=$(uname -m)
    case "$arch" in
        aarch64|arm64) arch="arm64" ;;
        x86_64|amd64) arch="x64" ;;
        *) echo -e "${RED}Unsupported arch: $arch${NC}"; exit 1 ;;
    esac

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
        rosetta=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
        [ "$rosetta" = "1" ] && arch="arm64"
    fi

    combo="$os-$arch"
    case "$combo" in
        linux-x64|linux-arm64|darwin-x64|darwin-arm64|windows-x64) ;;
        *) echo -e "${RED}No binary for $combo${NC}"; exit 1 ;;
    esac

    if [ -z "$requested_version" ]; then
        echo -e "${MUTED}Fetching latest version...${NC}"
        specific_version=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')
        [ -n "$specific_version" ] || { echo -e "${RED}Could not fetch version${NC}"; exit 1; }
    else
        specific_version="${requested_version#v}"
    fi

    url="https://github.com/$REPO/releases/download/v${specific_version}/${APP}-${combo}.tar.gz"
    echo -e "${MUTED}Downloading ${APP}-${combo}.tar.gz (v${specific_version})...${NC}"

    tmp_dir=$(mktemp -d)
    trap "rm -rf '$tmp_dir'" EXIT

    if ! curl -fsSL -o "$tmp_dir/archive.tar.gz" "$url"; then
        # Try .zip for Windows
        url="https://github.com/$REPO/releases/download/v${specific_version}/${APP}-${combo}.zip"
        if ! curl -fsSL -o "$tmp_dir/archive.zip" "$url"; then
            echo -e "${RED}Download failed${NC}"; exit 1
        fi
        unzip -q "$tmp_dir/archive.zip" -d "$tmp_dir"
    else
        tar -xzf "$tmp_dir/archive.tar.gz" -C "$tmp_dir"
    fi

    mv "$tmp_dir/$APP" "$INSTALL_DIR/"
    chmod 755 "$INSTALL_DIR/$APP"
fi

# Add to PATH
if [[ "$no_modify_path" != "true" ]] && [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    current_shell=$(basename "$SHELL" 2>/dev/null || echo "bash")
    case "$current_shell" in
        fish) cfg="$HOME/.config/fish/config.fish" ;;
        zsh)  cfg="${ZDOTDIR:-$HOME}/.zshrc" ;;
        *)    cfg="$HOME/.bashrc" ;;
    esac
    if [ -f "$cfg" ] && [[ -w "$cfg" ]]; then
        grep -Fxq "export PATH=$INSTALL_DIR:\$PATH" "$cfg" 2>/dev/null || {
            echo -e "\n# grexcode" >> "$cfg"
            echo "export PATH=$INSTALL_DIR:\$PATH" >> "$cfg"
            echo -e "${GREEN}Added grexcode to PATH in $cfg${NC}"
        }
    fi
fi

echo -e ""
echo -e "${MUTED}                    ${NC}             ▄     "
echo -e "${MUTED}█▀▀█ █▀▀█ █▀▀▀ █░█░█ ${NC}█▀▀▀ █▀▀█ █▀▀▄ █▀▀ "
echo -e "${MUTED}█░▄▄ █▄▄▀ █▀▀░ ▀▄▀▄▀ ${NC}█░░░ █░░█ █░█░ █▀▀ "
echo -e "${MUTED}▀▀▀▀ ▀░▀▀ ▀▀▀▀ ░▀░▀░ ${NC}▀▀▀▀ ▀▀▀▀ ▀▀▀░ ▀▀▀ "
echo -e ""
echo -e "${GREEN}Grexcode v${specific_version} installed!${NC}"
echo -e ""
echo -e "  cd <project>  ${MUTED}# Open directory${NC}"
echo -e "  grexcode      ${MUTED}# Run Grexcode${NC}"
echo -e ""
echo -e "${MUTED}Docs: ${NC}https://grexcode.ai/docs"
echo -e ""
