#!/bin/bash
# Grexcode Installer
# https://github.com/grexlabs/real_grexcode
set -euo pipefail

REPO="grexlabs/real_grexcode"
BINARY_NAME="grexcode"

detect_platform() {
    local os arch
    case "$(uname -s)" in
        Linux*)     os="linux" ;;
        Darwin*)    os="darwin" ;;
        MINGW*|MSYS*|CYGWIN*)  os="windows" ;;
        *) echo "Error: Unsupported OS"; exit 1 ;;
    esac
    case "$(uname -m)" in
        x86_64|amd64)   arch="x64" ;;
        aarch64|arm64)   arch="arm64" ;;
        armv7l|armhf)    arch="armv7" ;;
        i686|i386)       arch="x86" ;;
        *) echo "Error: Unsupported architecture"; exit 1 ;;
    esac
    echo "${os}-${arch}"
}

get_latest_version() {
    curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" | grep '"tag_name"' | head -1 | cut -d'"' -f4
}

install_grexcode() {
    local platform version filename url tmp_dir install_dir
    platform=$(detect_platform)
    version="${GREXCODE_VERSION:-$(get_latest_version)}"
    echo "Installing Grexcode ${version} for ${platform}..."

    case "${platform}" in
        linux-x64)      filename="grexcode-linux-x64" ;;
        linux-arm64)    filename="grexcode-linux-arm64" ;;
        linux-armv7)    filename="grexcode-linux-armv7" ;;
        linux-x86)      filename="grexcode-linux-x86" ;;
        darwin-x64)     filename="grexcode-darwin-x64" ;;
        darwin-arm64)   filename="grexcode-darwin-arm64" ;;
        windows-x64)    filename="grexcode-windows-x64.exe" ;;
        windows-arm64)  filename="grexcode-windows-arm64.exe" ;;
        *) echo "Error: No prebuilt binary for ${platform}"; exit 1 ;;
    esac

    url="https://github.com/${REPO}/releases/download/${version}/${filename}"

    if [ -n "${GREXCODE_INSTALL_DIR:-}" ]; then
        install_dir="${GREXCODE_INSTALL_DIR}"
    elif [ -n "${XDG_BIN_DIR:-}" ]; then
        install_dir="${XDG_BIN_DIR}"
    elif [ -n "${HOME:-}" ] && [ -w "${HOME}/.local/bin" ]; then
        install_dir="${HOME}/.local/bin"
    elif [ -w "/usr/local/bin" ]; then
        install_dir="/usr/local/bin"
    elif [ -n "${HOME:-}" ]; then
        install_dir="${HOME}/.local/bin"
        mkdir -p "${install_dir}"
    else
        echo "Error: Could not determine installation directory"; exit 1
    fi

    tmp_dir=$(mktemp -d)
    curl -fsSL -o "${tmp_dir}/${filename}" "${url}"
    chmod +x "${tmp_dir}/${filename}"
    mv "${tmp_dir}/${filename}" "${install_dir}/${BINARY_NAME}"
    rm -rf "${tmp_dir}"

    echo ""
    echo "Grexcode installed to: ${install_dir}/${BINARY_NAME}"
    case ":${PATH}:" in
        *":${install_dir}:"*) echo "Run 'grexcode' to get started!" ;;
        *) echo "Add ${install_dir} to your PATH, then run 'grexcode'!" ;;
    esac
}

install_grexcode
